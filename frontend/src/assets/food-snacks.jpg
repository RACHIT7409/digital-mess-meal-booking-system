  var mql = window.matchMedia('(prefers-color-scheme: dark)');
  function update(){
    var isDark = mql.matches;
    document.querySelectorAll('link.js-site-favicon').forEach(function(link){
      var target = isDark ? link.getAttribute('data-dark-href') : link.getAttribute('data-light-href');
      if (!target || link.getAttribute('href') === target) {
        return;
      }
      var replacement = link.cloneNode(true);
      replacement.setAttribute('href', target);
      link.parentNode.replaceChild(replacement, link);
    });
  }
  update();
  if (mql.addEventListener) {
    mql.addEventListener('change', update);
  } else if (mql.addListener) {
    mql.addListener(update);
  }
})();</script><link rel="preload" href="https://cdn.magnific.com/fkf/_next/static/media/0409375ebbe79c5a-s.p.woff2" as="font" type="font/woff2" crossorigin="anonymous" data-next-font="size-adjust"><link rel="preload" href="https://cdn.magnific.com/fkf/_next/static/media/d9d936c1adc8d7f0-s.p.woff2" as="font" type="font/woff2" crossorigin="anonymous" data-next-font="size-adjust"><link rel="preload" href="https://cdn.magnific.com/fkf/_next/static/media/351cea06258d2507-s.p.woff2" as="font" type="font/woff2" crossorigin="anonymous" data-next-font="size-adjust"><link rel="preload" href="https://cdn.magnific.com/fkf/_next/static/media/99fdc69fa1cb0964-s.p.woff2" as="font" type="font/woff2" crossorigin="anonymous" data-next-font="size-adjust"><link rel="preload" href="https://cdn.magnific.com/fkf/_next/static/media/9f01055e8352a6d2-s.p.woff2" as="font" type="font/woff2" crossorigin="anonymous" data-next-font="size-adjust"><link rel="preload" href="https://cdn.magnific.com/fkf/_next/static/media/fa1d478d7a35399e-s.p.woff2" as="font" type="font/woff2" crossorigin="anonymous" data-next-font="size-adjust"><link rel="preload" href="https://cdn.magnific.com/fkf/_next/static/media/e24502ad724d2ef3-s.p.woff2" as="font" type="font/woff2" crossorigin="anonymous" data-next-font="size-adjust"><script id="theme-init-script" data-nscript="beforeInteractive">
