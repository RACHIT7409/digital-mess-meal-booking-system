(function() {
  var hasAddedMeta = false;
  
  // Add the meta tag to the head
  function addAppleAppMeta() {
    if (hasAddedMeta) return;
    hasAddedMeta = true;
    
    var meta = document.createElement('meta');
    meta.name = "apple-itunes-app";
    meta.content = "app-id=1664092086, app-argument=" + window.location.href;
    document.getElementsByTagName('head')[0].appendChild(meta);
  }
  
  // Check if OneTrust is available and the user has interacted
  function checkOneTrustConsent() {
    if (typeof window.OneTrust !== 'undefined') {
      var hasInteracted = 
        window.OneTrust.IsAlertBoxClosed() || 
        localStorage.getItem('OptanonAlertBoxClosed') === 'true' ||
        document.cookie.indexOf('OptanonAlertBoxClosed=') !== -1;
      
      if (hasInteracted) {
        addAppleAppMeta();
        return true;
      }
    }
    return false;
  }
  
  // Instant verification
  if (checkOneTrustConsent()) return;
  
  // Listen for OneTrust events when available
  var checkInterval = setInterval(function() {
    if (typeof window.OneTrust !== 'undefined') {
      try {
        // Check consent immediately when OneTrust becomes available
        if (checkOneTrustConsent()) {
          clearInterval(checkInterval);
          return;
        }
        
        // Listener when the user accepts/rejects cookies
        window.OneTrust.OnConsentChanged(function() {
          addAppleAppMeta();
        });
      } catch (e) {
        console.log('OneTrust API error:', e);
      }
      clearInterval(checkInterval);
    }
  }, 500);
  
  // Fallback: listen for user clicks to verify state
  var clickHandler = function() {
    setTimeout(function() {
      if (checkOneTrustConsent()) {
        document.removeEventListener('click', clickHandler);
      }
    }, 1000);
  };
  document.addEventListener('click', clickHandler);
  
  // Cleanup after 30 seconds if OneTrust is not loaded
  setTimeout(function() {
    clearInterval(checkInterval);
    document.removeEventListener('click', clickHandler);
  }, 30000);
})();
